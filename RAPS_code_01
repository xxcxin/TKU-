function createAiHeatmapPlane() {
  if (!sceneReady || !scene) {
    setDebug('場景尚未準備完成，無法貼上 AI 熱力圖')
    return
  }

  clearAiHeatmapPlane()

  const textureLoader = new THREE.TextureLoader()

  textureLoader.load(
    aiHeatmapImageSrc,
    (texture) => {
      texture.colorSpace = THREE.SRGBColorSpace

      let center = new THREE.Vector3(0, 0, 0)
      let width = GRID_SIZE * 0.92
      let depth = GRID_SIZE * 0.92
      let planeY = 0.05

      if (terrainModel) {
        const terrainBox = new THREE.Box3().setFromObject(terrainModel)
        const terrainSize = terrainBox.getSize(new THREE.Vector3())

        if (terrainSize.length() > 0) {
          center = terrainBox.getCenter(new THREE.Vector3())
          width = Math.max(terrainSize.x, 1)
          depth = Math.max(terrainSize.z, 1)
          planeY = terrainBox.min.y + 0.08
        }
      }

      const geometry = new THREE.PlaneGeometry(width, depth)
      const material = new THREE.MeshBasicMaterial({
        map: texture,
        transparent: true,
        opacity: 0.9,
        side: THREE.DoubleSide,
        depthWrite: false
      })

      aiHeatmapPlane = new THREE.Mesh(geometry, material)
      aiHeatmapPlane.name = 'ai-heatmap-plane'
      aiHeatmapPlane.rotation.x = -Math.PI / 2
      aiHeatmapPlane.position.set(center.x, planeY, center.z)
      aiHeatmapPlane.renderOrder = 2
      aiHeatmapPlane.updateMatrixWorld(true)

      scene.add(aiHeatmapPlane)
      setDebug('AI 熱力圖已貼到右側預覽窗平面上')
    },
    undefined,
    (error) => {
      console.error(error)
      setDebug('AI 熱力圖載入失敗，請確認 public/map/AI.png 是否存在')
    }
  )
}

