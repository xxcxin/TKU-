async function confirmHeteroStreet() {
  if (!sceneReady || !scene) {
    setDebug('場景尚未準備完成')
    return
  }

  if (!roadSelectionMode.value) {
    setDebug('請先選擇 AI 熱力圖生成或手動選擇')
    return
  }

  if (roadSelectionMode.value === 'manual' && manualPathPoints.value.length < 2) {
    setDebug('請先用「線段選擇」在右側平面視圖至少點選 2 個點')
    return
  }

  isDrawingManualPath.value = false

  if (controls) {
    controls.enabled = true
  }

  try {
    clearMutationModels()
    resetMutationCounts()
    heteroPathGenerated.value = false

    if (roadSelectionMode.value === 'ai') {
      if (!aiRoadModel) {
        await insertAiRoadModel()
      } else {
        mutationModelCounts.value.aiRoad = countMeshInObject(aiRoadModel)
      }

      await insertAiTcodeModel()
    } else {
      await loadMutationModels([
        { key: 'heteroRoof', path: '/models/model-EACHVA-roof-AB.glb' },
        { key: 'heteroTcode', path: '/models/model-EACHVA-tcode-AB.glb' },
        { key: 'heteroRoof1', path: '/models/model-EACHVA-roof1-AB.glb' },
        { key: 'heteroPatharea', path: '/models/model-EACHVA-patharea-AB.glb' }
      ])

      rebuildManualPathPreview()
    }

    heteroStreetConfirmed.value = true

    // 確認後不還原視角，保留使用者在平面操作視角中旋轉、拖曳、縮放後的狀態。
    savedRoadSelectionView = null

    if (roadSelectionMode.value === 'ai') {
      setDebug('已確認 AI 熱力圖道路選擇，並載入 AI 垂直動線模型')
    } else {
      setDebug('已確認手動路徑，並載入異質變異基礎模型')
    }
  } catch (error) {
    console.error(error)
    setDebug(`異質變異基礎模型載入失敗：${error.message || error}`)
    alert(`異質變異基礎模型載入失敗：${error.message || error}`)
  }
}

async function generateHeteroPath() {
  if (!sceneReady || !scene) {
    setDebug('場景尚未準備完成')
    return
  }

  try {
    ;['heteroRaps', 'aiRaps'].forEach((key) => {
      if (mutationModelObjects[key]) {
        scene.remove(mutationModelObjects[key])
        disposeObject(mutationModelObjects[key])
        delete mutationModelObjects[key]
      }
    })

    const isAiMode = roadSelectionMode.value === 'ai'
    const modelKey = isAiMode ? 'aiRaps' : 'heteroRaps'
    const model = isAiMode
      ? await loadStaticGlbModelWithFallback([
        '/model-EACHVA-AI-RAPS-AB.glb',
        '/models/model-EACHVA-AI-RAPS-AB.glb'
      ])
      : await loadStaticGlbModel('/models/model-EACHVA-RAPS-AB.glb')

    mutationModelObjects[modelKey] = model
    applyModelVisualStyle(model, isAiMode ? mutationModelStyles.aiRaps : mutationModelStyles.heteroRaps)

    const reference = isAiMode
      ? (aiRoadModel || mutationModelObjects.aiTcode)
      : (
        mutationModelObjects.heteroRoof ||
        mutationModelObjects.heteroTcode ||
        mutationModelObjects.heteroRoof1 ||
        mutationModelObjects.heteroPatharea
      )

    if (reference) {
      applyTransformFromReference(model, reference)
    } else {
      fitGeneratedBuildingToScene(model, {
        preserveOriginalY: true
      })
    }

    scene.add(model)
    mutationModelCounts.value[modelKey] = countMeshInObject(model)
    heteroPathGenerated.value = true

    if (isAiMode) {
      setDebug(`已生成 AI 熱力圖活動路徑｜活動長度 ${heteroActivityLength.value}`)
    } else {
      setDebug(`已生成異質變異路徑｜活動長度 ${heteroActivityLength.value}`)
    }
  } catch (error) {
    console.error(error)
    setDebug(`異質變異路徑生成失敗：${error.message || error}`)
    alert(`異質變異路徑生成失敗：${error.message || error}`)
  }
}

async function loadMutationModels(modelConfigs) {
  let referenceModel = null

  for (const config of modelConfigs) {
    const model = await loadStaticGlbModel(config.path)
    mutationModelObjects[config.key] = model
    applyModelVisualStyle(model, mutationModelStyles[config.key])

    if (!referenceModel) {
      fitGeneratedBuildingToScene(model, {
        preserveOriginalY: true
      })
      referenceModel = model
    } else {
      applyTransformFromReference(model, referenceModel)
    }

    scene.add(model)
    mutationModelCounts.value[config.key] = countMeshInObject(model)
  }
}

// =========================
// 面積 / 體積計算
// =========================
function signedVolumeOfTriangle(p1, p2, p3) {
  return p1.dot(p2.clone().cross(p3)) / 6
}

function computeMeshVolume(mesh) {
  const geometry = mesh.geometry
  if (!geometry || !geometry.attributes?.position) return 0

  const pos = geometry.attributes.position
  const index = geometry.index
  let volume = 0

  mesh.updateWorldMatrix(true, false)
  const matrix = mesh.matrixWorld

  const p1 = new THREE.Vector3()
  const p2 = new THREE.Vector3()
  const p3 = new THREE.Vector3()

  if (index) {
    for (let i = 0; i < index.count; i += 3) {
      const a = index.getX(i)
      const b = index.getX(i + 1)
      const c = index.getX(i + 2)

      p1.fromBufferAttribute(pos, a).applyMatrix4(matrix)
      p2.fromBufferAttribute(pos, b).applyMatrix4(matrix)
      p3.fromBufferAttribute(pos, c).applyMatrix4(matrix)

      volume += signedVolumeOfTriangle(p1, p2, p3)
    }
  } else {
    for (let i = 0; i < pos.count; i += 3) {
      p1.fromBufferAttribute(pos, i).applyMatrix4(matrix)
      p2.fromBufferAttribute(pos, i + 1).applyMatrix4(matrix)
      p3.fromBufferAttribute(pos, i + 2).applyMatrix4(matrix)

      volume += signedVolumeOfTriangle(p1, p2, p3)
    }
  }

  return Math.abs(volume)
}

function computeObjectVolume(object) {
  let totalVolume = 0

  if (!object) return totalVolume

  object.updateMatrixWorld(true)

  object.traverse((child) => {
    if (child.isMesh) {
      totalVolume += computeMeshVolume(child)
    }
  })

  return totalVolume
}

function triangleAreaXZ(p1, p2, p3) {
  const ax = p2.x - p1.x
  const az = p2.z - p1.z
  const bx = p3.x - p1.x
  const bz = p3.z - p1.z

  return Math.abs((ax * bz - az * bx) * 0.5)
}

function computeMeshTopProjectedAreaXZ(mesh) {
  const geometry = mesh.geometry
  if (!geometry || !geometry.attributes?.position) return 0

  const pos = geometry.attributes.position
  const index = geometry.index

  mesh.updateWorldMatrix(true, false)
  const matrix = mesh.matrixWorld

  const p1 = new THREE.Vector3()
  const p2 = new THREE.Vector3()
  const p3 = new THREE.Vector3()
  const edgeA = new THREE.Vector3()
  const edgeB = new THREE.Vector3()
  const normal = new THREE.Vector3()

  let upArea = 0
  let downArea = 0
  let projectedArea = 0

  const readTriangle = (a, b, c) => {
    p1.fromBufferAttribute(pos, a).applyMatrix4(matrix)
    p2.fromBufferAttribute(pos, b).applyMatrix4(matrix)
    p3.fromBufferAttribute(pos, c).applyMatrix4(matrix)

    const area = triangleAreaXZ(p1, p2, p3)
    projectedArea += area

    edgeA.subVectors(p2, p1)
    edgeB.subVectors(p3, p1)
    normal.crossVectors(edgeA, edgeB).normalize()

    if (normal.y > 0.55) {
      upArea += area
    } else if (normal.y < -0.55) {
      downArea += area
    }
  }

  if (index) {
    for (let i = 0; i < index.count; i += 3) {
      readTriangle(index.getX(i), index.getX(i + 1), index.getX(i + 2))
    }
  } else {
    for (let i = 0; i < pos.count; i += 3) {
      readTriangle(i, i + 1, i + 2)
    }
  }

  if (upArea > 0) return upArea
  if (downArea > 0) return downArea
  return projectedArea
}

function computeObjectTopProjectedAreaXZ(object) {
  let totalArea = 0

  if (!object) return totalArea

  object.updateMatrixWorld(true)

  object.traverse((child) => {
    if (child.isMesh) {
      totalArea += computeMeshTopProjectedAreaXZ(child)
    }
  })

  return totalArea
}

function updateRenewalFloorAreaRatio() {
  if (!generatedBuilding || !roofAreaModel) {
    renewalFloorAreaRatio.value = 0
    return
  }

  const archVolume = computeObjectVolume(generatedBuilding)
  const totalFloorArea = archVolume / FLOOR_HEIGHT
  const roofProjectedArea = computeObjectTopProjectedAreaXZ(roofAreaModel)

  renewalFloorAreaRatio.value = roofProjectedArea > 0 ? totalFloorArea / roofProjectedArea : 0
}

// =========================
// 模型樣式 / 對位
// =========================
function applyModelVisualStyle(model, styleConfig) {
  if (!model || !styleConfig) return

  model.traverse((child) => {
    if (child.isMesh) {
      child.castShadow = true
      child.receiveShadow = true

      child.material = new THREE.MeshStandardMaterial({
        color: styleConfig.color,
        transparent: true,
        opacity: styleConfig.opacity,
        side: THREE.DoubleSide
      })
    }
  })
}

function applyTransformFromReference(model, referenceModel, extraOffset = {}) {
  if (!model || !referenceModel) return

  const { offsetX = 0, offsetY = 0, offsetZ = 0 } = extraOffset

  model.scale.copy(referenceModel.scale)
  model.rotation.copy(referenceModel.rotation)
  model.position.copy(referenceModel.position)

  model.position.x += offsetX
  model.position.y += offsetY
  model.position.z += offsetZ

  model.updateMatrixWorld(true)
}

function fitGeneratedBuildingToScene(model, options = {}) {
  const {
    rotationY = 0,
    offsetX = 0,
    offsetY = 0,
    offsetZ = 0,
    preserveOriginalY = false
  } = options

  const originalY = model.position.y

  model.position.set(0, preserveOriginalY ? originalY : 0, 0)
  model.scale.set(1, 1, 1)
  model.rotation.set(0, rotationY, 0)
  model.updateMatrixWorld(true)

  const buildingBox = new THREE.Box3().setFromObject(model)
  const buildingSize = buildingBox.getSize(new THREE.Vector3())

  if (buildingSize.length() === 0) {
    console.warn('GLB 尺寸為 0，無法對齊')
    return
  }

  let terrainCenter = new THREE.Vector3(0, 0, 0)
  let terrainSize = new THREE.Vector3(GRID_SIZE * 0.92, 0, GRID_SIZE * 0.92)
  let terrainMinY = 0

  if (terrainModel) {
    const terrainBox = new THREE.Box3().setFromObject(terrainModel)
    const currentTerrainSize = terrainBox.getSize(new THREE.Vector3())

    if (currentTerrainSize.length() > 0) {
      terrainCenter = terrainBox.getCenter(new THREE.Vector3())
      terrainSize = currentTerrainSize
      terrainMinY = terrainBox.min.y
    }
  }

  const scaleX = terrainSize.x / Math.max(buildingSize.x, 1)
  const scaleZ = terrainSize.z / Math.max(buildingSize.z, 1)
  const scale = Math.min(scaleX, scaleZ)

  model.scale.setScalar(scale)
  model.updateMatrixWorld(true)

  const scaledBox = new THREE.Box3().setFromObject(model)
  const scaledCenter = scaledBox.getCenter(new THREE.Vector3())

  model.position.x += terrainCenter.x - scaledCenter.x
  model.position.z += terrainCenter.z - scaledCenter.z
  model.updateMatrixWorld(true)

  if (!preserveOriginalY) {
    const alignedBox = new THREE.Box3().setFromObject(model)
    model.position.y += terrainMinY - alignedBox.min.y
    model.updateMatrixWorld(true)
  }

  model.position.x += offsetX
  model.position.y += offsetY
  model.position.z += offsetZ
  model.updateMatrixWorld(true)
}

function fitModelToGridBoundary(model) {
  model.position.set(0, 0, 0)
  model.scale.set(1, 1, 1)
  model.updateMatrixWorld(true)

  const rawBox = new THREE.Box3().setFromObject(model)
  const rawSize = rawBox.getSize(new THREE.Vector3())

  if (rawSize.length() === 0) {
    setDebug('模型尺寸為 0，無法縮放')
    return
  }

  const fitRatio = 0.92
  const targetFootprint = GRID_SIZE * fitRatio

  const modelWidth = rawSize.x
  const modelDepth = rawSize.z
  const horizontalMax = Math.max(modelWidth, modelDepth, 1)

  const scale = targetFootprint / horizontalMax
  model.scale.setScalar(scale)
  model.updateMatrixWorld(true)

  const box = new THREE.Box3().setFromObject(model)

  const bottomCenterX = (box.min.x + box.max.x) * 0.5
  const bottomCenterY = box.min.y
  const bottomCenterZ = (box.min.z + box.max.z) * 0.5

  model.position.x -= bottomCenterX
  model.position.y -= bottomCenterY
  model.position.z -= bottomCenterZ
  model.updateMatrixWorld(true)
}

function focusCameraOnObject(object) {
  if (!camera || !controls || !object) return

  const box = new THREE.Box3().setFromObject(object)
  const size = box.getSize(new THREE.Vector3())
  const center = box.getCenter(new THREE.Vector3())

  if (size.length() === 0) {
    setDebug('模型尺寸為 0，無法對焦')
    return
  }

  const maxDim = Math.max(size.x, size.y, size.z)
  const fov = camera.fov * (Math.PI / 180)
  let distance = maxDim / (2 * Math.tan(fov / 2))

  distance *= 1.8

  const direction = new THREE.Vector3(1, 0.75, 1).normalize()

  camera.up.set(0, 1, 0)
  camera.position.copy(center.clone().add(direction.multiplyScalar(distance)))
  controls.target.copy(center)
  camera.near = Math.max(0.1, distance / 1000)
  camera.far = Math.max(5000, distance * 20)
  camera.updateProjectionMatrix()
  controls.update()
}

function resetView() {
  if (!camera || !controls) return

  savedRoadSelectionView = null

  camera.up.set(0, 1, 0)
  camera.position.copy(initialCameraPosition)
  controls.target.copy(initialTargetPosition)
  camera.updateProjectionMatrix()
  controls.update()

  setDebug('視角已重設')
}

function toggleGrid() {
  if (!gridHelper) return
  showGrid.value = !showGrid.value
  gridHelper.visible = showGrid.value
}

function toggleAxes() {
  if (!axesHelper) return
  showAxes.value = !showAxes.value
  axesHelper.visible = showAxes.value
}

// =========================
// 清除模型
// =========================
function clearGeneratedBuildingModels() {
  if (generatedBuilding && scene) {
    scene.remove(generatedBuilding)
    disposeObject(generatedBuilding)
    generatedBuilding = null
  }

  if (generatedBuildingN && scene) {
    scene.remove(generatedBuildingN)
    disposeObject(generatedBuildingN)
    generatedBuildingN = null
  }

  stepApartmentCount.value = 0
  normalBuildingCount.value = 0
}

function clearRoofSpaceModels() {
  if (roofAreaModel && scene) {
    scene.remove(roofAreaModel)
    disposeObject(roofAreaModel)
    roofAreaModel = null
  }

  if (roofCommercialModel && scene) {
    scene.remove(roofCommercialModel)
    disposeObject(roofCommercialModel)
    roofCommercialModel = null
  }

  if (roofOpenModel && scene) {
    scene.remove(roofOpenModel)
    disposeObject(roofOpenModel)
    roofOpenModel = null
  }
}

function clearMutationModels() {
  Object.keys(mutationModelObjects).forEach((key) => {
    const obj = mutationModelObjects[key]
    if (obj && scene) {
      scene.remove(obj)
      disposeObject(obj)
      delete mutationModelObjects[key]
    }
  })
}

function resetMutationCounts() {
  mutationModelCounts.value = {
    heteroRoof: 0,
    heteroTcode: 0,
    heteroRoof1: 0,
    heteroPatharea: 0,
    heteroRaps: 0,
    aiRoad: 0,
    aiTcode: 0,
    aiRaps: 0
  }
}

function clearProjectModels() {
  savedRoadSelectionView = null

  if (terrainModel && scene) {
    scene.remove(terrainModel)
    disposeObject(terrainModel)
    terrainModel = null
  }

  clearGeneratedBuildingModels()
  clearRoofSpaceModels()
  clearAiHeatmapPlane()
  clearAiRoadModel()
  clearManualPath()

  roofSpaceGenerated.value = false
  roofUsableArea.value = 0
  roofCommercialArea.value = 0
  roofOpenArea.value = 0
  renewalFloorAreaRatio.value = 0
}

function disposeObject(object) {
  if (!object) return

  object.traverse((child) => {
    if (child.geometry) {
      child.geometry.dispose()
    }

    if (child.material) {
      if (Array.isArray(child.material)) {
        child.material.forEach((material) => {
          if (material && material.dispose) {
            material.dispose()
          }
        })
      } else if (child.material.dispose) {
        child.material.dispose()
      }
    }
  })
}

// =========================
// Watch / Lifecycle
// =========================
watch(currentStep, async (newStep) => {
  if (newStep === 1) {
    await nextTick()

    if (!overviewRef.value) return

    if (overviewRenderer) {
      if (overviewRenderer.domElement.parentNode) {
        overviewRenderer.domElement.parentNode.removeChild(overviewRenderer.domElement)
      }

      overviewRenderer.dispose()
      overviewRenderer = null
    }

    overviewCamera = null
    initOverviewScene()
  }
})

onMounted(async () => {
  await nextTick()
  initScene()
})

onBeforeUnmount(() => {
  window.removeEventListener('resize', onWindowResize)

  if (animationId) {
    cancelAnimationFrame(animationId)
  }

  if (renderer?.domElement) {
    renderer.domElement.removeEventListener('pointerdown', handleManualPathPointerDown)
  }

  clearProjectModels()

  if (controls) {
    controls.dispose()
    controls = null
  }

  if (renderer) {
    renderer.dispose()

    if (renderer.domElement && renderer.domElement.parentNode) {
      renderer.domElement.parentNode.removeChild(renderer.domElement)
    }

    renderer = null
  }

  if (overviewRenderer) {
    overviewRenderer.dispose()

    if (overviewRenderer.domElement && overviewRenderer.domElement.parentNode) {
      overviewRenderer.domElement.parentNode.removeChild(overviewRenderer.domElement)
    }

    overviewRenderer = null
  }

  scene = null
  camera = null
  overviewCamera = null
  sceneReady = false
})
