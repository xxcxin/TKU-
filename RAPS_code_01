function getManualDrawingPlaneY() {
  if (!terrainModel) return 0

  const box = new THREE.Box3().setFromObject(terrainModel)

  if (!Number.isFinite(box.min.y)) return 0

  return box.min.y + 0.35
}

function getPointerPointOnDrawingPlane(event) {
  if (!renderer || !camera || !raycaster) return null

  const rect = renderer.domElement.getBoundingClientRect()

  pointerNdc.x = ((event.clientX - rect.left) / rect.width) * 2 - 1
  pointerNdc.y = -((event.clientY - rect.top) / rect.height) * 2 + 1

  raycaster.setFromCamera(pointerNdc, camera)

  const planeY = getManualDrawingPlaneY()
  drawingPlane.set(new THREE.Vector3(0, 1, 0), -planeY)

  const point = new THREE.Vector3()
  const hit = raycaster.ray.intersectPlane(drawingPlane, point)

  return hit ? point : null
}

function handleManualPathPointerDown(event) {
  if (!isDrawingManualPath.value) return
  if (event.button !== 0) return

  const point = getPointerPointOnDrawingPlane(event)
  if (!point) return

  manualPathPoints.value = [
    ...manualPathPoints.value,
    point.clone()
  ]

  rebuildManualPathPreview()

  setDebug(`已新增第 ${manualPathPoints.value.length} 個路徑點`)
}

function createPathCylinderBetweenPoints(startPoint, endPoint) {
  const direction = new THREE.Vector3().subVectors(endPoint, startPoint)
  const length = direction.length()

  if (length <= 0.001) return null

  const geometry = new THREE.CylinderGeometry(0.55, 0.55, length, 12)
  const material = new THREE.MeshStandardMaterial({
    color: manualPathStyle.color,
    transparent: true,
    opacity: manualPathStyle.opacity,
    side: THREE.DoubleSide
  })

  const cylinder = new THREE.Mesh(geometry, material)

  cylinder.position.copy(startPoint).add(endPoint).multiplyScalar(0.5)
  cylinder.quaternion.setFromUnitVectors(
    new THREE.Vector3(0, 1, 0),
    direction.clone().normalize()
  )

  return cylinder
}

function createPathPointMarker(point) {
  const geometry = new THREE.SphereGeometry(1.6, 16, 16)
  const material = new THREE.MeshStandardMaterial({
    color: manualPathStyle.color,
    transparent: true,
    opacity: manualPathStyle.opacity
  })

  const sphere = new THREE.Mesh(geometry, material)
  sphere.position.copy(point)

  return sphere
}

function rebuildManualPathPreview() {
  if (!scene) return

  if (manualPathGroup) {
    scene.remove(manualPathGroup)
    disposeObject(manualPathGroup)
    manualPathGroup = null
  }

  manualPathGroup = new THREE.Group()
  manualPathGroup.name = 'manual-drawn-path'

  const points = manualPathPoints.value

  points.forEach((point) => {
    const marker = createPathPointMarker(point)
    manualPathGroup.add(marker)
  })

  for (let i = 0; i < points.length - 1; i += 1) {
    const segment = createPathCylinderBetweenPoints(points[i], points[i + 1])

    if (segment) {
      manualPathGroup.add(segment)
    }
  }

  scene.add(manualPathGroup)
}

