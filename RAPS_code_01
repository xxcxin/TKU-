<script setup>
import { computed, nextTick, onBeforeUnmount, onMounted, ref, watch } from 'vue'
import * as THREE from 'three'
import { OrbitControls } from 'three/examples/jsm/controls/OrbitControls.js'
import { GLTFLoader } from 'three/examples/jsm/loaders/GLTFLoader.js'
import { DXFLoader } from 'three-dxf-loader'

// =========================
// 基本 DOM / 共用狀態
// =========================
const containerRef = ref(null)
const overviewRef = ref(null)
const fileInputRef = ref(null)

const showWelcomeModal = ref(true)
const showUpdateModal = ref(false)

const userName = ref('')
const selectedFile = ref(null)
const selectedFileName = ref('')
const currentModelName = ref('')

const pendingFile = ref(null)
const pendingFileName = ref('')

const showGrid = ref(true)
const showAxes = ref(true)
const debugMessage = ref('等待初始化場景')

const currentStep = ref(1)
const TOTAL_STEPS = 3

// =========================
// 模型顏色設定
// =========================
const buildingStepStyle = {
  color: '#ffffff',
  opacity: 1
}

const buildingNormalStyle = {
  color: '#bdbdbd',
  opacity: 0.75
}

const roofAreaStyle = {
  color: '#ff684d',
  opacity: 0.35
}

const caModelStyle = {
  roof1: {
    color: '#ffb71c',
    opacity: 0.8
  },
  roof0: {
    color: '#ffffff',
    opacity: 0.3
  }
}

const mutationModelStyles = {
  heteroRoof: { color: '#ffffff', opacity: 0.6 },
  heteroTcode: { color: '#ff9a66', opacity: 0.8 },
  heteroRoof1: { color: '#ffcc4d', opacity: 0.7 },
  heteroPatharea: { color: '#76b7ff', opacity: 0.68 },
  heteroRaps: { color: '#ff4d4d', opacity: 0.95 },
  aiRoad: { color: '#ff4d4d', opacity: 0.95 },
  aiTcode: { color: '#ff9a66', opacity: 0.8 },
  aiRaps: { color: '#ff4d4d', opacity: 0.95 }
}

const manualPathStyle = {
  color: mutationModelStyles.heteroRaps.color,
  opacity: mutationModelStyles.heteroRaps.opacity
}

// =========================
// 第一頁建物資料
// =========================
const stepApartmentCount = ref(0)
const normalBuildingCount = ref(0)

const totalBuildingCount = computed(() => {
  return stepApartmentCount.value + normalBuildingCount.value
})

const buildingGenerated = computed(() => {
  return totalBuildingCount.value > 0
})

const buildingPieDashArray = computed(() => {
  const radius = 42
  const circumference = 2 * Math.PI * radius
  const total = totalBuildingCount.value

  if (total <= 0) {
    return `0 ${circumference}`
  }

  const stepLength = (stepApartmentCount.value / total) * circumference
  return `${stepLength} ${circumference - stepLength}`
})

// =========================
// 第二頁屋頂空間資料
// =========================
const roofSpaceGenerated = ref(false)
const roofUsableArea = ref(0)
const roofCommercialArea = ref(0)
const roofOpenArea = ref(0)

const roofTotalProgramArea = computed(() => {
  return roofCommercialArea.value + roofOpenArea.value
})

const roofCommercialPercent = computed(() => {
  if (roofTotalProgramArea.value <= 0) return 0
  return (roofCommercialArea.value / roofTotalProgramArea.value) * 100
})

const roofOpenPercent = computed(() => {
  if (roofTotalProgramArea.value <= 0) return 0
  return (roofOpenArea.value / roofTotalProgramArea.value) * 100
})

const roofPieDashArray = computed(() => {
  const radius = 42
  const circumference = 2 * Math.PI * radius
  const total = roofTotalProgramArea.value

  if (total <= 0) {
    return `0 ${circumference}`
  }

  const commercialLength = (roofCommercialArea.value / total) * circumference
  return `${commercialLength} ${circumference - commercialLength}`
})

// =========================
// 第三頁異質變異資料
// =========================
const heteroStreetConfirmed = ref(false)
const heteroActivityLength = ref(1000)
const heteroPathGenerated = ref(false)

const roadSelectionMode = ref('')
const aiHeatmapVisible = ref(false)
const aiHeatmapImageSrc = '/map/AI.png'
const aiRoadModelGenerated = ref(false)

const mutationModelCounts = ref({
  heteroRoof: 0,
  heteroTcode: 0,
  heteroRoof1: 0,
  heteroPatharea: 0,
  heteroRaps: 0,
  aiRoad: 0,
  aiTcode: 0,
  aiRaps: 0
})

const mutationHeteroStyleDetails = [
  { modelKey: 'heteroRoof', label: '活動屋頂' },
  { modelKey: 'heteroTcode', label: '步登公寓垂直動線' },
  { modelKey: 'heteroPatharea', label: '屋頂公共空間' },
  { modelKey: 'heteroRoof1', label: '屋頂商業空間' }
]

const mutationAiStyleDetails = [
  { modelKey: 'aiRoad', label: 'AI熱力圖道路' },
  { modelKey: 'aiTcode', label: '步登公寓垂直動線' }
]

const activeMutationStyleDetails = computed(() => {
  return roadSelectionMode.value === 'ai' ? mutationAiStyleDetails : mutationHeteroStyleDetails
})

const mutationSummaryRows = computed(() => {
  if (roadSelectionMode.value === 'ai') {
    return [
      [
        { modelKey: 'aiRoad', label: 'AI熱力圖道路' },
        { modelKey: 'aiTcode', label: '步登公寓垂直動線' }
      ]
    ]
  }

  return [
    [
      { modelKey: 'heteroRoof', label: '活動屋頂' },
      { modelKey: 'heteroTcode', label: '步登公寓垂直動線' }
    ],
    [
      { modelKey: 'heteroPatharea', label: '屋頂公共空間' },
      { modelKey: 'heteroRoof1', label: '屋頂商業空間' }
    ]
  ]
})

const activeRapsModelKey = computed(() => {
  return roadSelectionMode.value === 'ai' ? 'aiRaps' : 'heteroRaps'
})

const heteroSuggestedRangeText = computed(() => {
  const base = Number(heteroActivityLength.value || 0)
  return `${Math.max(0, base)} ~ ${Math.max(0, base + 500)}`
})

// =========================
// 手動畫線資料
// =========================
const isDrawingManualPath = ref(false)
const manualPathPoints = ref([])

let manualPathGroup = null
let raycaster = null
let savedRoadSelectionView = null
const pointerNdc = new THREE.Vector2()
const drawingPlane = new THREE.Plane(new THREE.Vector3(0, 1, 0), 0)

// =========================
// 圖例資料
// =========================
const visibleLegendItems = computed(() => {
  if (currentStep.value === 1 && buildingGenerated.value) {
    return [
      {
        key: 'building-step',
        label: '步登公寓',
        color: buildingStepStyle.color,
        opacity: buildingStepStyle.opacity
      },
      {
        key: 'building-normal',
        label: '一般建築',
        color: buildingNormalStyle.color,
        opacity: buildingNormalStyle.opacity
      }
    ]
  }

  if (currentStep.value === 2 && roofSpaceGenerated.value) {
    return [
      {
        key: 'roof-commercial',
        label: '屋頂商業空間',
        color: caModelStyle.roof1.color,
        opacity: caModelStyle.roof1.opacity
      },
      {
        key: 'roof-open',
        label: '屋頂開放空間',
        color: caModelStyle.roof0.color,
        opacity: caModelStyle.roof0.opacity
      },
      {
        key: 'roof-area',
        label: '屋頂可用範圍',
        color: roofAreaStyle.color,
        opacity: roofAreaStyle.opacity
      }
    ]
  }

  if (currentStep.value === 3) {
    const items = []

    if (roadSelectionMode.value === 'ai') {
      if (aiRoadModelGenerated.value) {
        items.push({
          key: 'ai-road',
          label: 'AI熱力圖道路',
          color: mutationModelStyles.aiRoad.color,
          opacity: mutationModelStyles.aiRoad.opacity
        })
      }

      if (heteroStreetConfirmed.value) {
        items.push({
          key: 'ai-tcode',
          label: '步登公寓垂直動線',
          color: mutationModelStyles.aiTcode.color,
          opacity: mutationModelStyles.aiTcode.opacity
        })
      }

      if (heteroPathGenerated.value) {
        items.push({
          key: 'ai-raps',
          label: '活動路徑',
          color: mutationModelStyles.aiRaps.color,
          opacity: mutationModelStyles.aiRaps.opacity
        })
      }

      return items
    }

    if (manualPathPoints.value.length >= 2 || heteroPathGenerated.value) {
      items.push({
        key: 'hetero-raps',
        label: '活動路徑',
        color: mutationModelStyles.heteroRaps.color,
        opacity: mutationModelStyles.heteroRaps.opacity
      })
    }

    if (heteroStreetConfirmed.value) {
      items.push(
        {
          key: 'hetero-tcode',
          label: '步登公寓垂直動線',
          color: mutationModelStyles.heteroTcode.color,
          opacity: mutationModelStyles.heteroTcode.opacity
        },
        {
          key: 'hetero-patharea',
          label: '屋頂公共空間',
          color: mutationModelStyles.heteroPatharea.color,
          opacity: mutationModelStyles.heteroPatharea.opacity
        },
        {
          key: 'hetero-roof1',
          label: '屋頂商業空間',
          color: mutationModelStyles.heteroRoof1.color,
          opacity: mutationModelStyles.heteroRoof1.opacity
        }
      )
    }

    return items
  }

  return []
})

// =========================
// Three.js 場景變數
// =========================
let scene = null
let camera = null
let renderer = null
let controls = null
let animationId = null

let overviewCamera = null
let overviewRenderer = null

let gridHelper = null
let axesHelper = null
let terrainModel = null
let generatedBuilding = null
let generatedBuildingN = null
let roofAreaModel = null
let roofCommercialModel = null
let roofOpenModel = null
let aiHeatmapPlane = null
let aiRoadModel = null

const mutationModelObjects = {}

let sceneReady = false

const GRID_SIZE = 400
const GRID_DIVISIONS = 40

const FLOOR_HEIGHT = 3
const renewalFloorAreaRatio = ref(0)

const initialCameraPosition = new THREE.Vector3(160, 120, 160)
const initialTargetPosition = new THREE.Vector3(0, 20, 0)

const canStart = computed(() => {
  return userName.value.trim() !== '' && !!selectedFile.value
})

function setDebug(message) {
  debugMessage.value = message
  console.log('[RAPS DEBUG]', message)
}

function formatArea(value) {
  return Number(value || 0).toFixed(2)
}

function formatPercent(value) {
  return `${Number(value || 0).toFixed(1)}%`
}

function getMutationCount(modelKey) {
  return mutationModelCounts.value[modelKey] || 0
}

function countMeshInObject(object) {
  let count = 0

  if (!object) return count

  object.traverse((child) => {
    if (child.isMesh) {
      count += 1
    }
  })

  return count
}

// =========================
// 頁面切換
// =========================
function goNextStep() {
  if (currentStep.value < TOTAL_STEPS) {
    currentStep.value += 1
  }
