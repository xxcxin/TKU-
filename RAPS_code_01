function saveRoadSelectionViewerState() {
  if (!camera || !controls) return
  if (savedRoadSelectionView) return

  savedRoadSelectionView = {
    position: camera.position.clone(),
    up: camera.up.clone(),
    target: controls.target.clone(),
    near: camera.near,
    far: camera.far,
    zoom: camera.zoom
  }
}

function restoreRoadSelectionViewerState() {
  if (!camera || !controls) return

  if (!savedRoadSelectionView) {
    camera.up.set(0, 1, 0)
    camera.position.copy(initialCameraPosition)
    controls.target.copy(initialTargetPosition)
    camera.near = 0.1
    camera.far = 5000
    camera.zoom = 1
    camera.updateProjectionMatrix()
    controls.update()
    return
  }

  camera.position.copy(savedRoadSelectionView.position)
  camera.up.copy(savedRoadSelectionView.up)
  controls.target.copy(savedRoadSelectionView.target)
  camera.near = savedRoadSelectionView.near
  camera.far = savedRoadSelectionView.far
  camera.zoom = savedRoadSelectionView.zoom
  camera.updateProjectionMatrix()
  controls.update()

  savedRoadSelectionView = null
}

function setViewerToTopPlanView() {
  if (!camera || !controls) return

  // 只在按下 AI / 手動選擇時切換一次平面操作視角。
  // 之後使用者旋轉、拖曳、縮放後，不再於確定時還原或重置視角。
  savedRoadSelectionView = null

  let center = new THREE.Vector3(0, 0, 0)
  let size = new THREE.Vector3(GRID_SIZE, 1, GRID_SIZE)

  if (terrainModel) {
    const box = new THREE.Box3().setFromObject(terrainModel)
    const boxSize = box.getSize(new THREE.Vector3())

    if (boxSize.length() > 0) {
      center = box.getCenter(new THREE.Vector3())
      size = boxSize
    }
  }

  const distance = Math.max(size.x, size.z, GRID_SIZE) * 1.28
  const direction = new THREE.Vector3(0.28, 1.55, 0.28).normalize()

  // 平面操作視角，但保留一般 3D OrbitControls 的 up 設定，旋轉時不會亂掉。
  camera.up.set(0, 1, 0)
  camera.position.copy(center.clone().add(direction.multiplyScalar(distance)))
  controls.target.copy(center)
  controls.enabled = true
  camera.near = 0.1
  camera.far = Math.max(5000, distance * 6)
  camera.updateProjectionMatrix()
  controls.update()
}

