<template>
  <div class="app-layout">
    <!-- 左側側頁 -->
    <aside class="sidebar">
      <div class="sidebar-header">
        <h1 class="sidebar-title-main">CAUR</h1>
        <p class="sidebar-title-sub">屋頂都市再生生成系統</p>

        <div class="sidebar-meta-row">
          <div class="meta-inline-card">
            <span class="meta-inline-label">使用者</span>
            <span class="meta-inline-value">{{ userName || '尚未輸入' }}</span>
          </div>

          <div class="meta-inline-card file-meta-inline-card">
            <span class="meta-inline-label">地形圖</span>
            <span class="meta-inline-value file-name-inline">
              {{ currentModelName || '尚未載入' }}
            </span>

            <button
              class="icon-btn"
              type="button"
              title="更新檔案"
              @click="openUpdateModal"
            >
              <span class="icon-btn-symbol">🗁</span>
            </button>
          </div>
        </div>
      </div>

      <div class="sidebar-content">
        <div class="terrain-panel">
          <div class="terrain-panel-title">地形圖</div>

          <div class="terrain-preview-box">
            <div ref="overviewRef" class="terrain-preview-canvas"></div>
          </div>

          <button class="generate-btn" type="button" @click="insertGeneratedBuilding">
            建物生成
          </button>
        </div>
      </div>

      <!-- 側頁內小彈窗 -->
      <div v-if="showUpdateModal" class="side-modal-overlay">
        <div class="side-modal-card">
          <button class="side-modal-close" type="button" @click="closeUpdateModal">
            ×
          </button>

          <div class="side-modal-title">更新檔案</div>

          <div class="side-modal-body">
            <button class="open-file-btn" type="button" @click="openFilePicker">
              開啟新檔案
            </button>

            <p class="side-modal-file-text">
              {{ pendingFileName || '尚未選擇新檔案' }}
            </p>
          </div>

          <div class="side-modal-footer">
            <button class="modal-cancel-btn" type="button" @click="closeUpdateModal">
              取消
            </button>

            <button
              class="modal-confirm-btn"
              type="button"
              :disabled="!pendingFile"
              @click="confirmUpdateFile"
            >
              確定
            </button>
          </div>
        </div>
      </div>
    </aside>

    <!-- 右側預覽區 -->
    <main class="viewer-area">
      <div class="viewer-frame">
        <div ref="containerRef" class="three-canvas"></div>
      </div>

      <div class="debug-box">
        {{ debugMessage }}
      </div>

      <div class="preview-toolbar">
        <button class="toolbar-btn" @click="resetView">重設視角</button>
        <button class="toolbar-btn" @click="toggleGrid">格線</button>
        <button class="toolbar-btn" @click="toggleAxes">軸</button>
      </div>

      <input
        ref="fileInputRef"
        type="file"
        class="hidden-file-input"
        accept=".svg,.glb,.gltf"
        @change="handleFileChangeWrapper"
      />
    </main>

    <!-- 開始前彈窗 -->
    <div v-if="showWelcomeModal" class="modal-overlay">
      <div class="modal-card">
        <h1 class="modal-title">CAUR 屋頂都市再生生成系統</h1>

        <p class="modal-text">welcome</p>

        <div class="modal-block">
          <label class="modal-label">使用者名稱</label>
          <input
            v-model="userName"
            type="text"
            class="modal-input"
            placeholder="請輸入使用者名稱"
          />
        </div>

        <div class="modal-block">
          <button class="modal-action-btn" @click="openFilePicker">
            導入地形圖
          </button>

          <p class="modal-file-text">
            {{ selectedFileName || '尚未選擇檔案' }}
          </p>
        </div>

        <div class="modal-footer">
          <button
            class="modal-start-btn"
            :disabled="!canStart"
            @click="handleStart"
          >
            開始
          </button>
        </div>
      </div>
    </div>
  </div>
</template>

<script setup>
import { computed, nextTick, onBeforeUnmount, onMounted, ref } from 'vue'
import * as THREE from 'three'
import { OrbitControls } from 'three/examples/jsm/controls/OrbitControls.js'
import { GLTFLoader } from 'three/examples/jsm/loaders/GLTFLoader.js'
import { SVGLoader } from 'three/examples/jsm/loaders/SVGLoader.js'

const containerRef = ref(null)
const overviewRef = ref(null)
const fileInputRef = ref(null)

const showWelcomeModal = ref(true)
const showUpdateModal = ref(false)

const userName = ref('')
const selectedFile = ref(null)
const selectedFileName = ref('')
const currentModelName = ref('')

const pendingFile = ref(null)
const pendingFileName = ref('')

const showGrid = ref(true)
const showAxes = ref(true)

const debugMessage = ref('等待初始化場景')

const canStart = computed(() => {
  return userName.value.trim() !== '' && !!selectedFile.value
})

let scene = null
let camera = null
let renderer = null
let controls = null
let animationId = null

let overviewCamera = null
let overviewRenderer = null

let gridHelper = null
let axesHelper = null
let terrainModel = null
let generatedBuilding = null
let sceneReady = false

const GRID_SIZE = 400
const GRID_DIVISIONS = 40

const initialCameraPosition = new THREE.Vector3(160, 120, 160)
const initialTargetPosition = new THREE.Vector3(0, 20, 0)

function setDebug(message) {
  debugMessage.value = message
  console.log('[CAUR DEBUG]', message)
}

function openFilePicker() {
  if (!fileInputRef.value) return
  fileInputRef.value.value = ''
  fileInputRef.value.click()
}

function handleInitialFile(event) {
  const file = event.target.files?.[0]
  if (!file) return

  selectedFile.value = file
  selectedFileName.value = file.name
  setDebug(`已選擇檔案：${file.name}`)
}

function handlePendingFile(event) {
  const file = event.target.files?.[0]
  if (!file) return

  pendingFile.value = file
  pendingFileName.value = file.name
  setDebug(`已選擇更新檔案：${file.name}`)
}

function handleFileChangeWrapper(event) {
  if (showWelcomeModal.value) {
    handleInitialFile(event)
  } else {
    handlePendingFile(event)
  }
}

async function handleStart() {
  if (!canStart.value) return

  showWelcomeModal.value = false
  await nextTick()

  if (!sceneReady) {
    initScene()
  }

  if (!sceneReady) {
    setDebug('場景初始化失敗，無法載入模型')
    return
  }

  await loadModelFromFile(selectedFile.value, { preserveView: false })
}

function openUpdateModal() {
  if (showWelcomeModal.value) return

  pendingFile.value = null
  pendingFileName.value = ''
  showUpdateModal.value = true
}

function closeUpdateModal() {
  pendingFile.value = null
  pendingFileName.value = ''
  showUpdateModal.value = false
}

async function confirmUpdateFile() {
  if (!pendingFile.value) return

  if (!sceneReady) {
    setDebug('場景尚未準備完成，無法更新檔案')
    return
  }

  await loadModelFromFile(pendingFile.value, { preserveView: true })
  closeUpdateModal()
}

function getFileExtension(fileName) {
  const parts = fileName.toLowerCase().split('.')
  return parts.length > 1 ? parts.pop() : ''
}

function initScene() {
  if (sceneReady) {
    setDebug('場景已存在')
    return
  }

  const container = containerRef.value
  if (!container) {
    setDebug('containerRef 為空，場景建立失敗')
    return
  }

  scene = new THREE.Scene()
  scene.background = new THREE.Color(0xf5f5f5)

  const width = Math.max(container.clientWidth, 1)
  const height = Math.max(container.clientHeight, 1)

  camera = new THREE.PerspectiveCamera(45, width / height, 0.1, 5000)
  camera.position.copy(initialCameraPosition)

  renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true })
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2))
  renderer.setSize(width, height)
  renderer.outputColorSpace = THREE.SRGBColorSpace

  container.innerHTML = ''
  container.appendChild(renderer.domElement)

  controls = new OrbitControls(camera, renderer.domElement)
  controls.enableDamping = true
  controls.target.copy(initialTargetPosition)
  controls.update()

  const ambientLight = new THREE.AmbientLight(0xffffff, 1.35)
  scene.add(ambientLight)

  const directionalLight = new THREE.DirectionalLight(0xffffff, 1.1)
  directionalLight.position.set(120, 160, 100)
  scene.add(directionalLight)

  gridHelper = new THREE.GridHelper(GRID_SIZE, GRID_DIVISIONS, 0x999999, 0xcccccc)
  gridHelper.position.set(0, 0, 0)
  scene.add(gridHelper)

  axesHelper = new THREE.AxesHelper(80)
  scene.add(axesHelper)

  initOverviewScene()

  sceneReady = true
  animate()
  window.addEventListener('resize', onWindowResize)

  setDebug('three 場景初始化完成')
}

function initOverviewScene() {
  const overviewContainer = overviewRef.value
  if (!overviewContainer) return

  const size = Math.max(overviewContainer.clientWidth, 1)

  // 視角範圍比格線再大一些
  const halfRange = GRID_SIZE * 0.7

  overviewCamera = new THREE.OrthographicCamera(
    -halfRange,
    halfRange,
    halfRange,
    -halfRange,
    0.1,
    5000
  )

  // 上視圖
  overviewCamera.position.set(0, 600, 0)
  overviewCamera.up.set(0, 0, -1)
  overviewCamera.lookAt(0, 0, 0)

  overviewRenderer = new THREE.WebGLRenderer({ antialias: true, alpha: true })
  overviewRenderer.setPixelRatio(Math.min(window.devicePixelRatio, 2))
  overviewRenderer.setSize(size, size)
  overviewRenderer.outputColorSpace = THREE.SRGBColorSpace

  overviewContainer.innerHTML = ''
  overviewContainer.appendChild(overviewRenderer.domElement)
}

function animate() {
  animationId = requestAnimationFrame(animate)

  if (controls) {
    controls.update()
  }

  if (renderer && scene && camera) {
    renderer.render(scene, camera)
  }

  if (overviewRenderer && scene && overviewCamera) {
    overviewRenderer.render(scene, overviewCamera)
  }
}

function onWindowResize() {
  const container = containerRef.value
  if (!container || !camera || !renderer) return

  const width = Math.max(container.clientWidth, 1)
  const height = Math.max(container.clientHeight, 1)

  camera.aspect = width / height
  camera.updateProjectionMatrix()
  renderer.setSize(width, height)

  const overviewContainer = overviewRef.value
  if (overviewContainer && overviewRenderer && overviewCamera) {
    const overviewSize = Math.max(overviewContainer.clientWidth, 1)
    overviewRenderer.setSize(overviewSize, overviewSize)
    overviewCamera.updateProjectionMatrix()
  }
}

async function loadModelFromFile(file, options = { preserveView: true }) {
  if (!file) {
    setDebug('未選擇檔案')
    return
  }

  if (!sceneReady || !scene) {
    setDebug('scene 尚未建立')
    return
  }

  const { preserveView = true } = options
  const extension = getFileExtension(file.name)

  setDebug(`開始載入：${file.name}`)

  if (terrainModel) {
    scene.remove(terrainModel)
    disposeObject(terrainModel)
    terrainModel = null
  }

  try {
    if (extension === 'glb' || extension === 'gltf') {
      terrainModel = await loadGlbFile(file)
    } else if (extension === 'svg') {
      terrainModel = await loadSvgFile(file)
    } else {
      throw new Error(`不支援的檔案格式：.${extension}`)
    }

    if (!terrainModel) {
      throw new Error('模型物件為空')
    }

    currentModelName.value = file.name

    fitModelToGridBoundary(terrainModel)
    scene.add(terrainModel)
    focusCameraOnObject(terrainModel)

    if (!preserveView) {
      resetView()
      focusCameraOnObject(terrainModel)
    }

    setDebug(`載入完成：${file.name}`)
  } catch (error) {
    console.error('模型載入失敗:', error)
    setDebug(`模型載入失敗：${error.message || error}`)
    alert(`模型載入失敗：${error.message || error}`)
  }
}

function loadGlbFile(file) {
  return new Promise((resolve, reject) => {
    const loader = new GLTFLoader()
    const fileUrl = URL.createObjectURL(file)

    loader.load(
      fileUrl,
      (gltf) => {
        const root = gltf.scene

        root.traverse((child) => {
          if (child.isMesh) {
            child.castShadow = true
            child.receiveShadow = true
          }
        })

        URL.revokeObjectURL(fileUrl)
        resolve(root)
      },
      undefined,
      (error) => {
        URL.revokeObjectURL(fileUrl)
        reject(error)
      }
    )
  })
}

async function loadSvgFile(file) {
  const svgText = await file.text()
  const loader = new SVGLoader()
  const data = loader.parse(svgText)

  const root = new THREE.Group()
  root.name = 'SVG_ROOT'

  for (const path of data.paths) {
    const fillMaterial = new THREE.MeshBasicMaterial({
      color: new THREE.Color(path.color),
      side: THREE.DoubleSide,
      depthWrite: false
    })

    const shapes = SVGLoader.createShapes(path)

    for (const shape of shapes) {
      const geometry = new THREE.ShapeGeometry(shape)
      const mesh = new THREE.Mesh(geometry, fillMaterial)
      root.add(mesh)
    }

    if (path.userData?.style?.stroke && path.subPaths?.length) {
      const strokeColor = new THREE.Color(path.userData.style.stroke)
      const pointsMaterial = new THREE.LineBasicMaterial({
        color: strokeColor
      })

      for (const subPath of path.subPaths) {
        const points = subPath.getPoints()
        const geometry = new THREE.BufferGeometry().setFromPoints(points)
        const line = new THREE.Line(geometry, pointsMaterial)
        root.add(line)
      }
    }
  }

// SVG 原本是 2D XY
// 先轉成 XZ 地面，再在水平面旋轉 180 度
root.rotation.x = -Math.PI / 2
root.rotation.y = Math.PI
root.updateMatrixWorld(true)

  const box = new THREE.Box3().setFromObject(root)
  const size = box.getSize(new THREE.Vector3())

  if (size.length() === 0) {
    throw new Error('SVG 有載入，但尺寸為 0')
  }

  return root
}

async function insertGeneratedBuilding() {
  if (!sceneReady || !scene) {
    setDebug('場景尚未準備完成')
    return
  }

  try {
    if (generatedBuilding) {
      scene.remove(generatedBuilding)
      disposeObject(generatedBuilding)
      generatedBuilding = null
    }

    const loader = new GLTFLoader()

    const gltf = await new Promise((resolve, reject) => {
      loader.load(
        '/models/model-arch.glb',
        (data) => resolve(data),
        undefined,
        (error) => reject(error)
      )
    })

generatedBuilding = gltf.scene
generatedBuilding.name = 'generated-building'

// 讓 GLB 與 SVG 方向一致
generatedBuilding.rotation.y = Math.PI

generatedBuilding.traverse((child) => {
  if (child.isMesh) {
    child.castShadow = true
    child.receiveShadow = true
  }
})

fitGeneratedBuildingToScene(generatedBuilding)
scene.add(generatedBuilding)

    setDebug('已置入 /model-arch.glb')
  } catch (error) {
    console.error(error)
    setDebug('建物生成失敗')
    alert(`建物生成失敗：${error.message || error}`)
  }
}

function fitGeneratedBuildingToScene(model) {
  const BUILDING_OFFSET_X = -1.1
  const BUILDING_OFFSET_Y = 0
  const BUILDING_OFFSET_Z =-2.3

  

  model.position.set(0, 0, 0)
  model.scale.set(1, 1, 1)

  // 先把 GLB 方向轉正
  model.rotation.set(0, Math.PI, 0)
  model.updateMatrixWorld(true)

  const buildingBox = new THREE.Box3().setFromObject(model)
  const buildingSize = buildingBox.getSize(new THREE.Vector3())

  if (buildingSize.length() === 0) {
    console.warn('GLB 尺寸為 0，無法對齊')
    return
  }

  let terrainCenter = new THREE.Vector3(0, 0, 0)
  let terrainSize = new THREE.Vector3(GRID_SIZE * 0.92, 0, GRID_SIZE * 0.92)
  let terrainMinY = 0

  if (terrainModel) {
    const terrainBox = new THREE.Box3().setFromObject(terrainModel)
    const currentTerrainSize = terrainBox.getSize(new THREE.Vector3())

    if (currentTerrainSize.length() > 0) {
      terrainCenter = terrainBox.getCenter(new THREE.Vector3())
      terrainSize = currentTerrainSize
      terrainMinY = terrainBox.min.y
    }
  }

  const scaleX = terrainSize.x / Math.max(buildingSize.x, 1)
  const scaleZ = terrainSize.z / Math.max(buildingSize.z, 1)
  const scale = Math.min(scaleX, scaleZ)

  model.scale.setScalar(scale)
  model.updateMatrixWorld(true)

  // 縮放後重算 box
  const scaledBox = new THREE.Box3().setFromObject(model)
  const scaledCenter = scaledBox.getCenter(new THREE.Vector3())

  // 對齊 SVG 中心
  model.position.x += terrainCenter.x - scaledCenter.x
  model.position.z += terrainCenter.z - scaledCenter.z
  model.updateMatrixWorld(true)

  // 對齊底部高度
  const alignedBox = new THREE.Box3().setFromObject(model)
  model.position.y += terrainMinY - alignedBox.min.y
  model.updateMatrixWorld(true)

  // 最後人工微調
  model.position.x += BUILDING_OFFSET_X
  model.position.y += BUILDING_OFFSET_Y
  model.position.z += BUILDING_OFFSET_Z
  model.updateMatrixWorld(true)

  const finalBox = new THREE.Box3().setFromObject(model)
  const finalCenter = finalBox.getCenter(new THREE.Vector3())
  const finalSize = finalBox.getSize(new THREE.Vector3())

  console.log('[terrainCenter]', terrainCenter)
  console.log('[terrainSize]', terrainSize)
  console.log('[finalBuildingCenter]', finalCenter)
  console.log('[finalBuildingSize]', finalSize)
}

function fitModelToGridBoundary(model) {
  model.position.set(0, 0, 0)
  model.scale.set(1, 1, 1)
  model.updateMatrixWorld(true)

  const rawBox = new THREE.Box3().setFromObject(model)
  const rawSize = rawBox.getSize(new THREE.Vector3())

  if (rawSize.length() === 0) {
    setDebug('模型尺寸為 0，無法縮放')
    return
  }

  const fitRatio = 0.92
  const targetFootprint = GRID_SIZE * fitRatio

  const modelWidth = rawSize.x
  const modelDepth = rawSize.z
  const horizontalMax = Math.max(modelWidth, modelDepth, 1)

  const scale = targetFootprint / horizontalMax
  model.scale.setScalar(scale)
  model.updateMatrixWorld(true)

  const box = new THREE.Box3().setFromObject(model)

  const bottomCenterX = (box.min.x + box.max.x) * 0.5
  const bottomCenterY = box.min.y
  const bottomCenterZ = (box.min.z + box.max.z) * 0.5

  model.position.x -= bottomCenterX
  model.position.y -= bottomCenterY
  model.position.z -= bottomCenterZ
  model.updateMatrixWorld(true)
}

function focusCameraOnObject(object) {
  if (!camera || !controls || !object) return

  const box = new THREE.Box3().setFromObject(object)
  const size = box.getSize(new THREE.Vector3())
  const center = box.getCenter(new THREE.Vector3())

  if (size.length() === 0) {
    setDebug('模型尺寸為 0，無法對焦')
    return
  }

  const maxDim = Math.max(size.x, size.y, size.z)
  const fov = camera.fov * (Math.PI / 180)
  let distance = maxDim / (2 * Math.tan(fov / 2))

  distance *= 1.8

  const direction = new THREE.Vector3(1, 0.75, 1).normalize()

  camera.position.copy(center.clone().add(direction.multiplyScalar(distance)))
  controls.target.copy(center)
  camera.near = Math.max(0.1, distance / 1000)
  camera.far = Math.max(5000, distance * 20)
  camera.updateProjectionMatrix()
  controls.update()
}

function resetView() {
  if (!camera || !controls) return

  camera.position.copy(initialCameraPosition)
  controls.target.copy(initialTargetPosition)
  camera.updateProjectionMatrix()
  controls.update()

  setDebug('視角已重設')
}

function toggleGrid() {
  if (!gridHelper) return
  showGrid.value = !showGrid.value
  gridHelper.visible = showGrid.value
}

function toggleAxes() {
  if (!axesHelper) return
  showAxes.value = !showAxes.value
  axesHelper.visible = showAxes.value
}

function disposeObject(object) {
  object.traverse((child) => {
    if (child.geometry) {
      child.geometry.dispose()
    }

    if (child.material) {
      if (Array.isArray(child.material)) {
        child.material.forEach((material) => {
          if (material && material.dispose) {
            material.dispose()
          }
        })
      } else if (child.material.dispose) {
        child.material.dispose()
      }
    }
  })
}

onMounted(async () => {
  await nextTick()
  initScene()
})

onBeforeUnmount(() => {
  window.removeEventListener('resize', onWindowResize)

  if (animationId) {
    cancelAnimationFrame(animationId)
  }

  if (terrainModel && scene) {
    scene.remove(terrainModel)
    disposeObject(terrainModel)
    terrainModel = null
  }

  if (generatedBuilding && scene) {
    scene.remove(generatedBuilding)
    disposeObject(generatedBuilding)
    generatedBuilding = null
  }

  if (controls) {
    controls.dispose()
    controls = null
  }

  if (renderer) {
    renderer.dispose()

    if (renderer.domElement && renderer.domElement.parentNode) {
      renderer.domElement.parentNode.removeChild(renderer.domElement)
    }

    renderer = null
  }

  if (overviewRenderer) {
    overviewRenderer.dispose()

    if (overviewRenderer.domElement && overviewRenderer.domElement.parentNode) {
      overviewRenderer.domElement.parentNode.removeChild(overviewRenderer.domElement)
    }

    overviewRenderer = null
  }

  scene = null
  camera = null
  overviewCamera = null
  sceneReady = false
})
</script>

