<!-- ==================== 第 3 頁 ==================== -->
<template v-else-if="currentStep === 3">
  <div class="step-page">
    <button class="back-mini-btn" type="button" @click="goPrevStep">
      ← 回到上一頁
    </button>

    <!-- 第一段 -->
    <div class="step-page-card ca-card">
      <div class="volume-title">細胞自動機生成量體</div>

      <div class="volume-mode-row">
        <button
          type="button"
          class="mode-btn"
          :class="{ active: caVolumeMode === 'different' }"
          @click="handleCaVolumeModeChange('different')"
        >
          街廓不同容積
        </button>

        <button
          type="button"
          class="mode-btn"
          :class="{ active: caVolumeMode === 'full' }"
          @click="handleCaVolumeModeChange('full')"
        >
          大街廓容積分配
        </button>

        <button
          type="button"
          class="mode-btn"
          :class="{ active: caVolumeMode === 'renewal' }"
          @click="handleCaVolumeModeChange('renewal')"
        >
          都更容積分配
        </button>
      </div>

      <button class="generate-btn" type="button" @click="generateCaSpace">
        量體生成
      </button>
    </div>

    <!-- 第二段 -->
    <div class="step-page-card ca-card">
      <div class="volume-title">細胞自動機生成再生空間</div>

      <div class="pie-dual-wrap">
        <div class="pie-block">
          <svg viewBox="0 0 120 120" class="pie-chart">
            <circle
              cx="60"
              cy="60"
              r="42"
              fill="none"
              stroke="#e8e8e8"
              stroke-width="16"
            />
            <circle
              cx="60"
              cy="60"
              r="42"
              fill="none"
              stroke="#111111"
              stroke-width="16"
              :stroke-dasharray="caPieDashArray"
              :stroke-dashoffset="0"
              transform="rotate(-90 60 60)"
              stroke-linecap="butt"
            />
          </svg>

          <div class="analysis-text ca-two-line-text">
            <div>公領域 ｜ 私領域</div>
            <div>{{ caAliveCount }} 個單元 ｜ {{ caDeadCount }} 個單元</div>
          </div>

          <div class="analysis-total">
            共產生 {{ caTotalCount }} 個再生空間單元
          </div>
        </div>
      </div>

      <div class="analysis-text ca-two-line-text ca-extra-text">
        <div>屋頂一樓商業空間 ｜ 屋頂一樓開放空間</div>
        <div>{{ caRoof1Count }} 個單元 ｜ {{ caRoof0Count }} 個單元</div>
      </div>

      <div class="ca-legend">
        <div class="ca-legend-item">
          <span class="legend-dot legend-dead"></span>
          <span>私領域單元</span>
        </div>

        <div class="ca-legend-item">
          <span class="legend-dot legend-alive"></span>
          <span>公領域單元</span>
        </div>

        <div class="ca-legend-item">
          <span class="legend-dot legend-roof1"></span>
          <span>屋頂一樓商業空間單元</span>
        </div>

        <div class="ca-legend-item">
          <span class="legend-dot legend-roof0"></span>
          <span>屋頂一樓開放空間單元</span>
        </div>

        <div class="ca-legend-item">
          <span class="legend-dot legend-tcode"></span>
          <span>再生空間垂直動線</span>
        </div>
      </div>
    </div>
  </div>
</template>
