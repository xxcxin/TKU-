<script setup>
import { computed, nextTick, onBeforeUnmount, onMounted, ref, watch } from 'vue'
import * as THREE from 'three'
import { OrbitControls } from 'three/examples/jsm/controls/OrbitControls.js'
import { GLTFLoader } from 'three/examples/jsm/loaders/GLTFLoader.js'
import { SVGLoader } from 'three/examples/jsm/loaders/SVGLoader.js'

const containerRef = ref(null)
const overviewRef = ref(null)
const fileInputRef = ref(null)

const showWelcomeModal = ref(true)
const showUpdateModal = ref(false)

const userName = ref('')
const selectedFile = ref(null)
const selectedFileName = ref('')
const currentModelName = ref('')

const pendingFile = ref(null)
const pendingFileName = ref('')

const showGrid = ref(true)
const showAxes = ref(true)

const debugMessage = ref('等待初始化場景')

// 頁面步驟
const currentStep = ref(1)
const TOTAL_STEPS = 4

// 第一頁分析資料
const stepApartmentCount = ref(0)
const normalBuildingCount = ref(0)

const totalBuildingCount = computed(() => {
  return stepApartmentCount.value + normalBuildingCount.value
})

const pieDashArray = computed(() => {
  const radius = 42
  const circumference = 2 * Math.PI * radius
  const total = totalBuildingCount.value

  if (total <= 0) {
    return `0 ${circumference}`
  }

  const stepLength = (stepApartmentCount.value / total) * circumference
  return `${stepLength} ${circumference - stepLength}`
})

const pieDashOffset = computed(() => {
  return 0
})

// 第二頁資料
const volumeMode = ref('different')

const volumeAType = ref('住1')
const volumeBType = ref('住2')
const fullBlockVolumeType = ref('住1')

const blockOptions = [
  '街廓1',
  '街廓2',
  '街廓3',
  '街廓4',
  '街廓5',
  '街廓6',
  '街廓7',
  '街廓8',
  '街廓9',
  '街廓10',
  '街廓11',
  '街廓12'
]

const selectedBlocksA = ref([])
const renewalVolumeText = ref('xxxxx')
const resultBars = ref([])

const unselectedBlocks = computed(() => {
  return blockOptions.filter((block) => !selectedBlocksA.value.includes(block))
})

const unselectedBlocksText = computed(() => {
  if (unselectedBlocks.value.length === 0) {
    return '無'
  }

  return unselectedBlocks.value.join('、')
})

// 第三頁資料
const caAliveCount = ref(0)
const caDeadCount = ref(0)
const caRoof1Count = ref(0)
const caRoof0Count = ref(0)

const caTotalCount = computed(() => {
  return caAliveCount.value + caDeadCount.value
})

const caPieDashArray = computed(() => {
  const radius = 42
  const circumference = 2 * Math.PI * radius
  const total = caTotalCount.value

  if (total <= 0) {
    return `0 ${circumference}`
  }

  const aliveLength = (caAliveCount.value / total) * circumference
  return `${aliveLength} ${circumference - aliveLength}`
})

const canStart = computed(() => {
  return userName.value.trim() !== '' && !!selectedFile.value
})

const faModelStyle = {
  a: {
    color: '#ff6b6b',
    opacity: 0.78
  },
  b: {
    color: '#ffae00',
    opacity: 0.72
  },
  all: {
    color: '#4d7cff',
    opacity: 0.65
  },
  allRe: {
    color: '#ff7a59',
    opacity: 0.65
  }
}

const caModelStyle = {
  dead: {
    color: '#ffffff',
    opacity: 1
  },
  alive: {
    color: '#a7ffa7',
    opacity: 0.82
  },
  roof1: {
    color: '#ffb71c',
    opacity: 0.58
  },
  roof0: {
    color: '#8fd19e',
    opacity: 0.5
  },
  tcode: {
    color: '#ff8a5b',
    opacity: 0.78
  }
}

let scene = null
let camera = null
let renderer = null
let controls = null
let animationId = null

let overviewCamera = null
let overviewRenderer = null

let gridHelper = null
let axesHelper = null
let terrainModel = null
let generatedBuilding = null
let generatedBuildingN = null
let roofAreaModel = null

let faModelA = null
let faModelB = null
let faModelAll = null
let faModelAllRe = null

let caDeadModel = null
let caAliveModel = null
let caRoof1Model = null
let caRoof0Model = null
let caTcodeModel = null

let sceneReady = false

const GRID_SIZE = 400
const GRID_DIVISIONS = 40

const initialCameraPosition = new THREE.Vector3(160, 120, 160)
const initialTargetPosition = new THREE.Vector3(0, 20, 0)

function setDebug(message) {
  debugMessage.value = message
  console.log('[CAUR DEBUG]', message)
}

function formatUnit(value) {
  return Number(value || 0).toFixed(1)
}

function goNextStep() {
  if (currentStep.value < TOTAL_STEPS) {
    currentStep.value += 1
  }
}

function goPrevStep() {
  if (currentStep.value > 1) {
    currentStep.value -= 1
  }
}

function openFilePicker() {
  if (!fileInputRef.value) return
  fileInputRef.value.value = ''
  fileInputRef.value.click()
}

function handleInitialFile(event) {
  const file = event.target.files?.[0]
  if (!file) return

  selectedFile.value = file
  selectedFileName.value = file.name
  setDebug(`已選擇檔案：${file.name}`)
}

function handlePendingFile(event) {
  const file = event.target.files?.[0]
  if (!file) return

  pendingFile.value = file
  pendingFileName.value = file.name
  setDebug(`已選擇更新檔案：${file.name}`)
}

function handleFileChangeWrapper(event) {
  if (showWelcomeModal.value) {
    handleInitialFile(event)
  } else {
    handlePendingFile(event)
  }
}

async function handleStart() {
  if (!canStart.value) return

  showWelcomeModal.value = false
  await nextTick()

  if (!sceneReady) {
    initScene()
  }

  if (!sceneReady) {
    setDebug('場景初始化失敗，無法載入模型')
    return
  }

  await loadModelFromFile(selectedFile.value, { preserveView: false })
}

function openUpdateModal() {
  if (showWelcomeModal.value) return

  pendingFile.value = null
  pendingFileName.value = ''
  showUpdateModal.value = true
}

function closeUpdateModal() {
  pendingFile.value = null
  pendingFileName.value = ''
  showUpdateModal.value = false
}

async function confirmUpdateFile() {
  if (!pendingFile.value) return

  if (!sceneReady) {
    setDebug('場景尚未準備完成，無法更新檔案')
    return
  }

  await loadModelFromFile(pendingFile.value, { preserveView: true })
  closeUpdateModal()
}

function getFileExtension(fileName) {
  const parts = fileName.toLowerCase().split('.')
  return parts.length > 1 ? parts.pop() : ''
}

function initScene() {
  if (sceneReady) {
    setDebug('場景已存在')
    return
  }

  const container = containerRef.value
  if (!container) {
    setDebug('containerRef 為空，場景建立失敗')
    return
  }

  scene = new THREE.Scene()
  scene.background = new THREE.Color(0xf5f5f5)

  const width = Math.max(container.clientWidth, 1)
  const height = Math.max(container.clientHeight, 1)

  camera = new THREE.PerspectiveCamera(45, width / height, 0.1, 5000)
  camera.position.copy(initialCameraPosition)

  renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true })
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2))
  renderer.setSize(width, height)
  renderer.outputColorSpace = THREE.SRGBColorSpace

  container.innerHTML = ''
  container.appendChild(renderer.domElement)

  controls = new OrbitControls(camera, renderer.domElement)
  controls.enableDamping = true
  controls.target.copy(initialTargetPosition)
  controls.update()

  const ambientLight = new THREE.AmbientLight(0xffffff, 1.35)
  scene.add(ambientLight)

  const directionalLight = new THREE.DirectionalLight(0xffffff, 1.1)
  directionalLight.position.set(120, 160, 100)
  scene.add(directionalLight)

  gridHelper = new THREE.GridHelper(GRID_SIZE, GRID_DIVISIONS, 0x999999, 0xcccccc)
  gridHelper.position.set(0, 0, 0)
  scene.add(gridHelper)

  axesHelper = new THREE.AxesHelper(80)
  scene.add(axesHelper)

  initOverviewScene()

  sceneReady = true
  animate()
  window.addEventListener('resize', onWindowResize)

  setDebug('three 場景初始化完成')
}

function initOverviewScene() {
  const overviewContainer = overviewRef.value
  if (!overviewContainer) return

  const size = Math.max(overviewContainer.clientWidth, 1)
  const halfRange = GRID_SIZE * 0.7

  overviewCamera = new THREE.OrthographicCamera(
    -halfRange,
    halfRange,
    halfRange,
    -halfRange,
    0.1,
    5000
  )

  overviewCamera.position.set(0, 600, 0)
  overviewCamera.up.set(0, 0, -1)
  overviewCamera.lookAt(0, 0, 0)

  overviewRenderer = new THREE.WebGLRenderer({ antialias: true, alpha: true })
  overviewRenderer.setPixelRatio(Math.min(window.devicePixelRatio, 2))
  overviewRenderer.setSize(size, size)
  overviewRenderer.outputColorSpace = THREE.SRGBColorSpace

  overviewContainer.innerHTML = ''
  overviewContainer.appendChild(overviewRenderer.domElement)
}

function animate() {
  animationId = requestAnimationFrame(animate)

  if (controls) {
    controls.update()
  }

  if (renderer && scene && camera) {
    renderer.render(scene, camera)
  }

  if (overviewRenderer && scene && overviewCamera) {
    overviewRenderer.render(scene, overviewCamera)
  }
}

function onWindowResize() {
  const container = containerRef.value
  if (!container || !camera || !renderer) return

  const width = Math.max(container.clientWidth, 1)
  const height = Math.max(container.clientHeight, 1)

  camera.aspect = width / height
  camera.updateProjectionMatrix()
  renderer.setSize(width, height)

  const overviewContainer = overviewRef.value
  if (overviewContainer && overviewRenderer && overviewCamera) {
    const overviewSize = Math.max(overviewContainer.clientWidth, 1)
    overviewRenderer.setSize(overviewSize, overviewSize)
    overviewCamera.updateProjectionMatrix()
  }
}

async function loadModelFromFile(file, options = { preserveView: true }) {
  if (!file) {
    setDebug('未選擇檔案')
    return
  }

  if (!sceneReady || !scene) {
    setDebug('scene 尚未建立')
    return
  }

  const { preserveView = true } = options
  const extension = getFileExtension(file.name)

  setDebug(`開始載入：${file.name}`)

  if (terrainModel) {
    scene.remove(terrainModel)
    disposeObject(terrainModel)
    terrainModel = null
  }

  if (generatedBuilding) {
    scene.remove(generatedBuilding)
    disposeObject(generatedBuilding)
    generatedBuilding = null
  }

  if (generatedBuildingN) {
    scene.remove(generatedBuildingN)
    disposeObject(generatedBuildingN)
    generatedBuildingN = null
  }

  if (roofAreaModel) {
    scene.remove(roofAreaModel)
    disposeObject(roofAreaModel)
    roofAreaModel = null
  }

  clearFaModels()
  clearCaModels()
  resultBars.value = []

  caAliveCount.value = 0
  caDeadCount.value = 0
  caRoof1Count.value = 0
  caRoof0Count.value = 0

  stepApartmentCount.value = 0
  normalBuildingCount.value = 0

  try {
    if (extension === 'glb' || extension === 'gltf') {
      terrainModel = await loadGlbFile(file)
    } else if (extension === 'svg') {
      terrainModel = await loadSvgFile(file)
    } else {
      throw new Error(`不支援的檔案格式：.${extension}`)
    }

    if (!terrainModel) {
      throw new Error('模型物件為空')
    }

    currentModelName.value = file.name

    fitModelToGridBoundary(terrainModel)
    scene.add(terrainModel)
    focusCameraOnObject(terrainModel)

    if (!preserveView) {
      resetView()
      focusCameraOnObject(terrainModel)
    }

    setDebug(`載入完成：${file.name}`)
  } catch (error) {
    console.error('模型載入失敗:', error)
    setDebug(`模型載入失敗：${error.message || error}`)
    alert(`模型載入失敗：${error.message || error}`)
  }
}

function loadGlbFile(file) {
  return new Promise((resolve, reject) => {
    const loader = new GLTFLoader()
    const fileUrl = URL.createObjectURL(file)

    loader.load(
      fileUrl,
      (gltf) => {
        const root = gltf.scene

        root.traverse((child) => {
          if (child.isMesh) {
            child.castShadow = true
            child.receiveShadow = true
          }
        })

        URL.revokeObjectURL(fileUrl)
        resolve(root)
      },
      undefined,
      (error) => {
        URL.revokeObjectURL(fileUrl)
        reject(error)
      }
    )
  })
}

function loadStaticGlbModel(path) {
  return new Promise((resolve, reject) => {
    const loader = new GLTFLoader()

    loader.load(
      path,
      (gltf) => resolve(gltf.scene),
      undefined,
      async (error) => {
        console.error('GLB 載入失敗：', path, error)

        try {
          const response = await fetch(path)
          const text = await response.text()

          if (text.trim().startsWith('<!DOCTYPE') || text.trim().startsWith('<html')) {
            reject(new Error(`模型路徑錯誤或檔案不存在：${path}`))
            return
          }
        } catch (fetchError) {
          console.error(fetchError)
        }

        reject(error)
      }
    )
  })
}

async function loadSvgFile(file) {
  const svgText = await file.text()
  const loader = new SVGLoader()
  const data = loader.parse(svgText)

  const root = new THREE.Group()
  root.name = 'SVG_ROOT'

  for (const path of data.paths) {
    const fillMaterial = new THREE.MeshBasicMaterial({
      color: new THREE.Color(path.color),
      side: THREE.DoubleSide,
      depthWrite: false
    })

    const shapes = SVGLoader.createShapes(path)

    for (const shape of shapes) {
      const geometry = new THREE.ShapeGeometry(shape)
      const mesh = new THREE.Mesh(geometry, fillMaterial)
      root.add(mesh)
    }

    if (path.userData?.style?.stroke && path.subPaths?.length) {
      const strokeColor = new THREE.Color(path.userData.style.stroke)
      const pointsMaterial = new THREE.LineBasicMaterial({
        color: strokeColor
      })

      for (const subPath of path.subPaths) {
        const points = subPath.getPoints()
        const geometry = new THREE.BufferGeometry().setFromPoints(points)
        const line = new THREE.Line(geometry, pointsMaterial)
        root.add(line)
      }
    }
  }

  // SVG 原本是 2D XY
  // 先轉成 XZ 地面，再在水平面旋轉 180 度
  root.rotation.x = -Math.PI / 2
  root.rotation.y = Math.PI
  root.updateMatrixWorld(true)

  const box = new THREE.Box3().setFromObject(root)
  const size = box.getSize(new THREE.Vector3())

  if (size.length() === 0) {
    throw new Error('SVG 有載入，但尺寸為 0')
  }

  return root
}

