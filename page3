        {
          key: 'b',
          title: `容積B｜${volumeBType.value}`,
          units: unitB,
          color: faModelStyle.b.color,
          height: (unitB / maxUnits) * 100
        }
      ]

      setDebug('屋頂空間量體模擬完成｜模式：街廓不同容積')
      return
    }

    if (volumeMode.value === 'full') {
      faModelAll = await loadStaticGlbModel('/models/model-FA-ALL.glb')

