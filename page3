}

function fitGeneratedBuildingToScene(model, options = {}) {
  const {
    rotationY = Math.PI,
    offsetX = 0,
    offsetY = 0,
    offsetZ = 0,
    preserveOriginalY = false
  } = options

  const originalY = model.position.y

  model.position.set(0, preserveOriginalY ? originalY : 0, 0)
  model.scale.set(1, 1, 1)
  model.rotation.set(0, rotationY, 0)
  model.updateMatrixWorld(true)

  const buildingBox = new THREE.Box3().setFromObject(model)
  const buildingSize = buildingBox.getSize(new THREE.Vector3())

  if (buildingSize.length() === 0) {
    console.warn('GLB 尺寸為 0，無法對齊')
    return
  }

  let terrainCenter = new THREE.Vector3(0, 0, 0)
  let terrainSize = new THREE.Vector3(GRID_SIZE * 0.92, 0, GRID_SIZE * 0.92)
  let terrainMinY = 0

  if (terrainModel) {
    const terrainBox = new THREE.Box3().setFromObject(terrainModel)
    const currentTerrainSize = terrainBox.getSize(new THREE.Vector3())

    if (currentTerrainSize.length() > 0) {
      terrainCenter = terrainBox.getCenter(new THREE.Vector3())
      terrainSize = currentTerrainSize
      terrainMinY = terrainBox.min.y
    }
  }

  const scaleX = terrainSize.x / Math.max(buildingSize.x, 1)
  const scaleZ = terrainSize.z / Math.max(buildingSize.z, 1)
  const scale = Math.min(scaleX, scaleZ)

  model.scale.setScalar(scale)
  model.updateMatrixWorld(true)

  const scaledBox = new THREE.Box3().setFromObject(model)
  const scaledCenter = scaledBox.getCenter(new THREE.Vector3())

  model.position.x += terrainCenter.x - scaledCenter.x
  model.position.z += terrainCenter.z - scaledCenter.z
  model.updateMatrixWorld(true)

  if (!preserveOriginalY) {
    const alignedBox = new THREE.Box3().setFromObject(model)
    model.position.y += terrainMinY - alignedBox.min.y
    model.updateMatrixWorld(true)
  }

  model.position.x += offsetX
  model.position.y += offsetY
  model.position.z += offsetZ
  model.updateMatrixWorld(true)
}

function fitModelToGridBoundary(model) {
  model.position.set(0, 0, 0)
  model.scale.set(1, 1, 1)
  model.updateMatrixWorld(true)

  const rawBox = new THREE.Box3().setFromObject(model)
  const rawSize = rawBox.getSize(new THREE.Vector3())

  if (rawSize.length() === 0) {
    setDebug('模型尺寸為 0，無法縮放')
    return
  }

  const fitRatio = 0.92
  const targetFootprint = GRID_SIZE * fitRatio

  const modelWidth = rawSize.x
  const modelDepth = rawSize.z
  const horizontalMax = Math.max(modelWidth, modelDepth, 1)

  const scale = targetFootprint / horizontalMax
  model.scale.setScalar(scale)
  model.updateMatrixWorld(true)

  const box = new THREE.Box3().setFromObject(model)

  const bottomCenterX = (box.min.x + box.max.x) * 0.5
  const bottomCenterY = box.min.y
  const bottomCenterZ = (box.min.z + box.max.z) * 0.5

  model.position.x -= bottomCenterX
  model.position.y -= bottomCenterY
  model.position.z -= bottomCenterZ
  model.updateMatrixWorld(true)
}

function focusCameraOnObject(object) {
  if (!camera || !controls || !object) return

  const box = new THREE.Box3().setFromObject(object)
  const size = box.getSize(new THREE.Vector3())
  const center = box.getCenter(new THREE.Vector3())

  if (size.length() === 0) {
    setDebug('模型尺寸為 0，無法對焦')
    return
  }

  const maxDim = Math.max(size.x, size.y, size.z)
  const fov = camera.fov * (Math.PI / 180)
  let distance = maxDim / (2 * Math.tan(fov / 2))

  distance *= 1.8

  const direction = new THREE.Vector3(1, 0.75, 1).normalize()

  camera.position.copy(center.clone().add(direction.multiplyScalar(distance)))
  controls.target.copy(center)
  camera.near = Math.max(0.1, distance / 1000)
  camera.far = Math.max(5000, distance * 20)
  camera.updateProjectionMatrix()
  controls.update()
}

function resetView() {
  if (!camera || !controls) return

  camera.position.copy(initialCameraPosition)
  controls.target.copy(initialTargetPosition)
  camera.updateProjectionMatrix()
  controls.update()

  setDebug('視角已重設')
}

function toggleGrid() {
  if (!gridHelper) return
  showGrid.value = !showGrid.value
  gridHelper.visible = showGrid.value
}

function toggleAxes() {
  if (!axesHelper) return
  showAxes.value = !showAxes.value
  axesHelper.visible = showAxes.value
}

function disposeObject(object) {
  object.traverse((child) => {
    if (child.geometry) {
      child.geometry.dispose()
    }

    if (child.material) {
      if (Array.isArray(child.material)) {
        child.material.forEach((material) => {
          if (material && material.dispose) {
            material.dispose()
          }
        })
      } else if (child.material.dispose) {
        child.material.dispose()
      }
    }
  })
}

watch(currentStep, async (newStep) => {
  if (newStep === 1) {
