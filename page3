          key: 'all',
          title: fullBlockVolumeType.value,
          units: unitAll,
          color: faModelStyle.all.color,
          height: 100
        }
      ]

      setDebug('屋頂空間量體模擬完成｜模式：大街廓容積分配')
      return
    }

    faModelAllRe = await loadStaticGlbModel('/models/model-FA-ALL-RE.glb')

    applyModelVisualStyle(faModelAllRe, faModelStyle.allRe)

    fitGeneratedBuildingToScene(faModelAllRe, {
      rotationY: Math.PI,
      offsetX: -1.1,
      offsetY: 0,
      offsetZ: -2.3,
      preserveOriginalY: true
    })

    scene.add(faModelAllRe)

    const volumeAllRe = computeObjectVolume(faModelAllRe)
    const unitAllRe = volumeAllRe / 9

    resultBars.value = [
      {
        key: 'allRe',
        title: `總容積 ${renewalVolumeText.value}`,
        units: unitAllRe,
        color: faModelStyle.allRe.color,
        height: 100
      }
