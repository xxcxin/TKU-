      currentModelName.value || '尚未載入',
      item.textA || '',
      item.textB || '',
      item.deadCount || 0,
      item.aliveCount || 0,
      formatDensity(item.densityValue)
    ]
  })

  const csvLines = [
    headers.map(escapeCsvValue).join(','),
    ...rows.map((row) => row.map(escapeCsvValue).join(','))
  ]

  return '\uFEFF' + csvLines.join('\n')
}

