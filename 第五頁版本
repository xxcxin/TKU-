// 建立圓餅圖 conic-gradient
function buildMetricPieStyle(metricKey) {
  if (!sortedCompareItems.value.length) {
    return {
      background: 'conic-gradient(#e6e6e6 0% 100%)'
    }
  }

  const total = sortedCompareItems.value.reduce((sum, item) => {
    return sum + Number(item[metricKey] || 0)
  }, 0)

  if (total <= 0) {
    return {
      background: 'conic-gradient(#e6e6e6 0% 100%)'
    }
  }

  let start = 0
  const segments = sortedCompareItems.value.map((item, index) => {
    const value = Number(item[metricKey] || 0)
    const percent = (value / total) * 100
    const end = start + percent
    const color = getRankColor(index)
    const segment = `${color} ${start}% ${end}%`
    start = end
    return segment
  })

  return {
    background: `conic-gradient(${segments.join(', ')})`
  }
}

