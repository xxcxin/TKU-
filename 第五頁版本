async function loadModelFromFile(file, options = { preserveView: true }) {
  if (!file) {
    setDebug('未選擇檔案')
    return
  }

  if (!sceneReady || !scene) {
    setDebug('scene 尚未建立')
    return
  }

  const { preserveView = true } = options
  const extension = getFileExtension(file.name)

  console.log('載入檔案：', file.name)
  console.log('副檔名：', extension)
  setDebug(`開始載入：${file.name}`)

  if (terrainModel) {
    scene.remove(terrainModel)
    disposeObject(terrainModel)
    terrainModel = null
  }

  if (generatedBuilding) {
    scene.remove(generatedBuilding)
    disposeObject(generatedBuilding)
    generatedBuilding = null
  }

  if (generatedBuildingN) {
    scene.remove(generatedBuildingN)
    disposeObject(generatedBuildingN)
    generatedBuildingN = null
  }

  if (roofAreaModel) {
    scene.remove(roofAreaModel)
    disposeObject(roofAreaModel)
    roofAreaModel = null
  }

  clearFaModels()
  clearCaModels()
  clearMutationModels()
  resultBars.value = []

  caAliveCount.value = 0
  caDeadCount.value = 0
  caRoof1Count.value = 0
  caRoof0Count.value = 0

  stepApartmentCount.value = 0
  normalBuildingCount.value = 0
  compareItems.value = []
  selectedPreviewCompareId.value = ''
  compareMetricCache.value = {}
  renewalFloorAreaRatio.value = 0
  mutationSelectedItem.value = null
  mutationPreviewReady.value = false
  selectedMutationCardKey.value = ''

  try {
    if (extension === 'glb' || extension === 'gltf') {
      terrainModel = await loadGlbFile(file)
    } else if (extension === 'dxf') {
      terrainModel = await loadDxfFile(file)

      // DXF 左右水平反轉
      terrainModel.scale.x *= -1
      terrainModel.updateMatrixWorld(true)
    } else {
      throw new Error(`不支援的檔案格式：.${extension}`)
    }

    if (!terrainModel) {
      throw new Error('模型物件為空')
    }

      currentModelName.value = file.name

      fitModelToGridBoundary(terrainModel)

      // DXF 左右水平反轉
      if (extension === 'dxf') {
        terrainModel.scale.x *= -1
        terrainModel.updateMatrixWorld(true)
      }

      scene.add(terrainModel)
      focusCameraOnObject(terrainModel)

    if (!preserveView) {
      resetView()
      focusCameraOnObject(terrainModel)
    }

    setDebug(`載入完成：${file.name}`)
  } catch (error) {
    console.error('模型載入失敗:', error)
    setDebug(`模型載入失敗：${error.message || error}`)
    alert(`模型載入失敗：${error.message || error}`)
  }
}

function loadGlbFile(file) {
  return new Promise((resolve, reject) => {
    const loader = new GLTFLoader()
    const fileUrl = URL.createObjectURL(file)

    loader.load(
      fileUrl,
      (gltf) => {
        const root = gltf.scene

        root.traverse((child) => {
          if (child.isMesh) {
            child.castShadow = true
            child.receiveShadow = true
          }
        })

        URL.revokeObjectURL(fileUrl)
        resolve(root)
      },
      undefined,
      (error) => {
        URL.revokeObjectURL(fileUrl)
        reject(error)
      }
    )
  })
}

function loadStaticGlbModel(path) {
  return new Promise((resolve, reject) => {
    const loader = new GLTFLoader()

    loader.load(
      path,
      (gltf) => resolve(gltf.scene),
      undefined,
      async (error) => {
        console.error('GLB 載入失敗：', path, error)

        try {
          const response = await fetch(path)
          const text = await response.text()

          if (text.trim().startsWith('<!DOCTYPE') || text.trim().startsWith('<html')) {
            reject(new Error(`模型路徑錯誤或檔案不存在：${path}`))
            return
          }
        } catch (fetchError) {
          console.error(fetchError)
        }

        reject(error)
      }
    )
  })
}

async function loadDxfFile(file) {
  return new Promise((resolve, reject) => {
    const loader = new DXFLoader()
    const fileUrl = URL.createObjectURL(file)

    try {
      loader.setConsumeUnits?.(true)
      loader.setDefaultColor?.(0x111111)
      loader.setEnableLayer?.(true)
    } catch (configError) {
      console.warn('DXF loader 設定略過：', configError)
    }

    loader.load(
      fileUrl,
      (data) => {
        try {
          console.log('DXF 載入結果：', data)

          const root = data?.entity || data?.entities || data

          if (!root) {
            URL.revokeObjectURL(fileUrl)
            reject(new Error('DXF 載入成功，但沒有可顯示的 entity'))
            return
          }

          root.name = 'DXF_ROOT'
          root.rotation.x = -Math.PI / 2
          root.rotation.y = Math.PI
          root.updateMatrixWorld(true)

          const rawBox = new THREE.Box3().setFromObject(root)
          const rawSize = rawBox.getSize(new THREE.Vector3())

          if (rawSize.length() === 0) {
            URL.revokeObjectURL(fileUrl)
            reject(new Error('DXF 有載入，但尺寸為 0，可能是空檔或圖層內容不支援'))
            return
          }

          URL.revokeObjectURL(fileUrl)
          resolve(root)
        } catch (innerError) {
          URL.revokeObjectURL(fileUrl)
          reject(innerError)
        }
      },
      undefined,
      (error) => {
        URL.revokeObjectURL(fileUrl)
        console.error('DXF 載入失敗：', error)
        reject(new Error('DXF 格式不支援，請將檔案另存為 AutoCAD R2000 DXF 後再試一次'))
      }
    )
  })
}

