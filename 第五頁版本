function escapeCsvValue(value) {
  const text = String(value ?? '')
  const escaped = text.replace(/"/g, '""')
  return `"${escaped}"`
}

function buildCompareCsvContent() {
  const headers = [
    '排名',
    '選擇的底圖',
    '容積分配',
    '容積率',
    '新增居住單元總數',
