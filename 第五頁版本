// 讀取單一模式的評比數值
async function getCompareMetricsByModeKey(modeKey) {
  if (compareMetricCache.value[modeKey]) {
    return compareMetricCache.value[modeKey]
  }

  const config = getCompareModelConfig(modeKey)

  let deadModel = null
  let aliveModel = null

  try {
    deadModel = await loadStaticGlbModel(config.deadPath)
    aliveModel = await loadStaticGlbModel(config.alivePath)

    const deadCount = countMeshInObject(deadModel)
    const aliveCount = countMeshInObject(aliveModel)
    const densityValue = deadCount > 0 ? aliveCount / deadCount : 0

    const result = {
      deadCount,
      aliveCount,
      densityValue,
      deadPath: config.deadPath,
      alivePath: config.alivePath
    }

    compareMetricCache.value = {
      ...compareMetricCache.value,
      [modeKey]: result
    }

    disposeObject(deadModel)
    disposeObject(aliveModel)

    return result
  } catch (error) {
    console.error(error)

    if (deadModel) disposeObject(deadModel)
    if (aliveModel) disposeObject(aliveModel)

    throw error
  }
}

// 用於第四頁排序的完整資料
const sortedCompareItems = computed(() => {
  if (!compareItems.value.length) {
    return []
