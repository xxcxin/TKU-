async function loadMutationModels(modelConfigs, clearExisting = true) {
  clearFaModels()
  clearCaModels()
  if (clearExisting) {
    clearMutationModels()
  }

  let referenceModel = null
  const existingKeys = Object.keys(mutationModelObjects)
  if (existingKeys.length > 0) {
    referenceModel = mutationModelObjects[existingKeys[0]]
  }

  for (const config of modelConfigs) {
    const model = await loadStaticGlbModel(config.path)
    mutationModelObjects[config.key] = model
    applyModelVisualStyle(model, mutationModelStyles.value[config.key])

    if (!referenceModel) {
      fitGeneratedBuildingToScene(model, {
        rotationY: 0,
        offsetX: 0,
        offsetY: 0,
        offsetZ: 0,
        preserveOriginalY: true
      })
      referenceModel = model
    } else {
      applyTransformFromReference(model, referenceModel)
    }

    scene.add(model)
    mutationModelCounts.value[config.key] = countMeshInObject(model)
  }
}

