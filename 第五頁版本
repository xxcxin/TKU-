  const items = compareItems.value.map((item) => {
    const metrics = item.metrics || {}

    return {
      ...item,
      deadCount: metrics.deadCount || 0,
      aliveCount: metrics.aliveCount || 0,
      densityValue: metrics.densityValue || 0
    }
  })

  const totalDead = items.reduce((sum, item) => sum + item.deadCount, 0)
  const totalAlive = items.reduce((sum, item) => sum + item.aliveCount, 0)
  const totalDensity = items.reduce((sum, item) => sum + item.densityValue, 0)

  const withShare = items.map((item) => {
    const deadShare = totalDead > 0 ? (item.deadCount / totalDead) * 100 : 0
    const aliveShare = totalAlive > 0 ? (item.aliveCount / totalAlive) * 100 : 0
    const densityShare = totalDensity > 0 ? (item.densityValue / totalDensity) * 100 : 0
    const totalShare = deadShare + aliveShare + densityShare

    return {
      ...item,
      deadShare,
      aliveShare,
      densityShare,
      totalShare
    }
  })

  return withShare.sort((a, b) => b.totalShare - a.totalShare)
})

